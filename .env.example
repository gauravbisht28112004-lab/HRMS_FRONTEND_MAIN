# ----------------------------------------------------------------------
# Finbud HRMS Frontend — environment variable contract
# ----------------------------------------------------------------------
# Copy this file to `.env` (dev) or `.env.production.local` (prod) and
# fill in the values that fit your deployment.
# ----------------------------------------------------------------------

# Backend API base URL. MUST match the backend's
# `server.servlet.context-path` + `/api` (default: /api).
# Local dev:          http://localhost:8080/api
# Staging over HTTPS: https://hrms-staging.finbudfinancial.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# Optional. When set, every call to
#   api.attendance.punchIn  →  POST /attendance/punch-in
#   api.attendance.punchOut →  POST /attendance/punch-out
# will include the `X-Device-Api-Key` header with this value so the
# backend's DeviceApiKeyFilter lets the request through.
#
# Only set this for trusted kiosk / fingerprint-device builds — it
# bypasses user authentication for the punch routes by design.
# Leave empty for normal web-session builds; those users can't
# self-punch until the backend exposes `/attendance/me/punch-in`
# routes that derive employeeId from the JWT.
# VITE_DEVICE_API_KEY=change-me-to-the-device-secret
