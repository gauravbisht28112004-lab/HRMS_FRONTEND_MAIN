# ----------------------------------------------------------------------
# Finbud HRMS Frontend — PRODUCTION environment template
# ----------------------------------------------------------------------
# Copy to `.env.production.local` (untracked) on the build host. Vite
# embeds these values at build time; rebuild the bundle whenever any
# of them change.
# ----------------------------------------------------------------------

# Same origin as the backend so cookies + CORS stay simple. HTTPS only.
# Example: https://hrms.finbudfinancial.com/api
VITE_API_BASE_URL=https://hrms.finbudfinancial.com/api

# Only uncomment for a dedicated kiosk/biometric-device build that
# talks to /attendance/punch-in|out. Keep this value matching
# `system_config.attendance.device.api_key` on the backend.
# VITE_DEVICE_API_KEY=<rotate-per-device>
